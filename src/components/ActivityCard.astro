---
import type { CollectionEntry } from 'astro:content';

interface Props {
  activity: CollectionEntry<'activities'>;
}

const { activity } = Astro.props;
const { data } = activity;
---

<div class="space-y-3 pb-8">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
    <h3 class="text-lg font-semibold gradient-text">{data.title}</h3>
    <p class="text-sm text-muted-foreground">{data.date}</p>
  </div>
  
  <p class="text-sm text-foreground/80">
    <span class="font-medium">{data.role}</span>
    {data.organization && <span class="text-muted-foreground"></span>}
  </p>

  {data.description && (
    <p class="text-sm text-muted-foreground leading-relaxed">{data.description}</p>
  )}

  {data.accomplishments && data.accomplishments.length > 0 && (
    <ul class="text-sm text-muted-foreground space-y-1 ml-4">
      {data.accomplishments.map((accomplishment) => (
        <li class="list-disc">
          {accomplishment}
        </li>
      ))}
    </ul>
  )}
</div>
