---
import { getDimensionsFromAspectRatio } from '../lib/image';

export interface Photo {
  src: string;
  caption: string;
  aspectRatio?: string;
}

interface Props {
  photos: Photo[];
}

const { photos } = Astro.props;
---

<div class="columns-1 md:columns-2 lg:columns-3 gap-4 space-y-4">
  {photos.map((photo) => {
    const imageDimensions = getDimensionsFromAspectRatio(photo.aspectRatio, 1000, '1 / 1');

    return (
      <div
        class="relative break-inside-avoid overflow-hidden rounded-xl border border-border group cursor-pointer bg-card/60"
        style={{ aspectRatio: photo.aspectRatio || '1 / 1' }}
      >
        <img
          src={photo.src}
          alt={photo.caption}
          width={imageDimensions.width}
          height={imageDimensions.height}
          loading="lazy"
          decoding="async"
          sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-background/85 via-background/15 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
          <p class="text-foreground text-sm font-medium">{photo.caption}</p>
        </div>
      </div>
    );
  })}
</div>

<style>
  .columns-1 {
    column-count: 1;
  }

  @media (min-width: 768px) {
    .md\:columns-2 {
      column-count: 2;
    }
  }

  @media (min-width: 1024px) {
    .lg\:columns-3 {
      column-count: 3;
    }
  }

  .break-inside-avoid {
    break-inside: avoid;
  }

  .space-y-4 > * + * {
    margin-top: 1rem;
  }

  .group > img {
    display: block;
  }
</style>
