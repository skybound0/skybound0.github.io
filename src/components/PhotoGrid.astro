---
export interface Photo {
  src: string;
  caption: string;
  aspectRatio?: string;
}

interface Props {
  photos: Photo[];
}

const { photos } = Astro.props;
---

<div class="columns-1 md:columns-2 lg:columns-3 gap-4 space-y-4">
  {photos.map((photo) => (
    <div
      class="relative break-inside-avoid overflow-hidden rounded-xl border border-white/10 group cursor-pointer"
      style={{ aspectRatio: photo.aspectRatio || '1 / 1' }}
    >
      <img
        src={photo.src}
        alt={photo.caption}
        class="w-full h-full object-cover transition-transform group-hover:scale-105"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
        <p class="text-white text-sm font-medium">{photo.caption}</p>
      </div>
    </div>
  ))}
</div>

<style>
  .columns-1 {
    column-count: 1;
  }

  @media (min-width: 768px) {
    .md\:columns-2 {
      column-count: 2;
    }
  }

  @media (min-width: 1024px) {
    .lg\:columns-3 {
      column-count: 3;
    }
  }

  .break-inside-avoid {
    break-inside: avoid;
  }

  .space-y-4 > * + * {
    margin-top: 1rem;
  }

  .group > img {
    display: block;
  }
</style>
