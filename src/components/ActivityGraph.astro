---
import type { CollectionEntry } from 'astro:content';

interface Props {
  activities: CollectionEntry<'activities'>[];
}

const { activities } = Astro.props;

const MONTH_MAP: Record<string, number> = {
  jan: 0,
  january: 0,
  feb: 1,
  february: 1,
  mar: 2,
  march: 2,
  apr: 3,
  april: 3,
  may: 4,
  jun: 5,
  june: 5,
  jul: 6,
  july: 6,
  aug: 7,
  august: 7,
  sep: 8,
  sept: 8,
  september: 8,
  oct: 9,
  october: 9,
  nov: 10,
  november: 10,
  dec: 11,
  december: 11,
};

function parseDateToken(rawToken: string): number {
  const token = rawToken.trim().toLowerCase();

  if (!token) {
    return Number.NEGATIVE_INFINITY;
  }

  if (token.includes('present') || token.includes('current') || token.includes('now')) {
    return Date.now();
  }

  const monthYearMatch = token.match(/([a-z]+)\s+(\d{4})/i);
  if (monthYearMatch) {
    const month = MONTH_MAP[monthYearMatch[1].toLowerCase()];
    const year = Number(monthYearMatch[2]);
    if (!Number.isNaN(month) && !Number.isNaN(year)) {
      return new Date(year, month, 1).getTime();
    }
  }

  const yearMatch = token.match(/\b(19|20)\d{2}\b/);
  if (yearMatch) {
    return new Date(Number(yearMatch[0]), 0, 1).getTime();
  }

  return Number.NEGATIVE_INFINITY;
}

function getRecencyScore(dateText: string): number {
  const normalized = dateText.replace(/\u2013/g, '-');
  const parts = normalized
    .split('-')
    .map((part) => part.trim())
    .filter(Boolean);

  if (parts.length === 0) {
    return Number.NEGATIVE_INFINITY;
  }

  const mostRecentPart = parts[parts.length - 1];
  const mostRecentScore = parseDateToken(mostRecentPart);

  if (mostRecentScore !== Number.NEGATIVE_INFINITY) {
    return mostRecentScore;
  }

  const fallbackScore = parseDateToken(parts[0]);
  return fallbackScore;
}

function getInitials(name: string): string {
  const words = name.trim().split(/\s+/).filter(Boolean);
  if (words.length === 0) {
    return '?';
  }
  if (words.length === 1) {
    return words[0].slice(0, 2).toUpperCase();
  }
  return `${words[0][0]}${words[words.length - 1][0]}`.toUpperCase();
}

function getSeededUnit(seed: string): number {
  let hash = 2166136261;

  for (let i = 0; i < seed.length; i += 1) {
    hash ^= seed.charCodeAt(i);
    hash = Math.imul(hash, 16777619);
  }

  return (hash >>> 0) / 4294967295;
}

const activitiesSorted = [...activities].sort((a, b) => {
  const scoreA = getRecencyScore(a.data.date);
  const scoreB = getRecencyScore(b.data.date);
  return scoreB - scoreA;
});

const GOLDEN_ANGLE = Math.PI * (3 - Math.sqrt(5));
const total = Math.max(1, activitiesSorted.length);
const INNER_RADIUS_PCT = 5;
const OUTER_RADIUS_PCT = 42;
const COLLISION_PADDING_PCT = 2;
const COLLISION_ITERATIONS = 280;
const CENTER_PULL = 0.002;

type NodeLayout = {
  activity: CollectionEntry<'activities'>;
  xPct: number;
  yPct: number;
  sizePct: number;
  initials: string;
  zIndex: number;
};

const nodes: NodeLayout[] = activitiesSorted.map((activity, index) => {
  const recencyWeight = total <= 1 ? 1 : 1 - index / (total - 1);
  const seedBase = `${activity.id}-${activity.data.organization}-${index}`;

  const angleJitter = (getSeededUnit(`${seedBase}-angle`) - 0.5) * 0.95;
  const radiusJitter = (getSeededUnit(`${seedBase}-radius`) - 0.5) * 5.5;

  const baseAngle = -Math.PI / 2 + index * GOLDEN_ANGLE;
  const angle = baseAngle + angleJitter;

  const spiralRadius = Math.sqrt((index + 0.5) / total) * (OUTER_RADIUS_PCT - INNER_RADIUS_PCT);
  const centerBias = (1 - recencyWeight) * 2.2;
  const radius = Math.max(INNER_RADIUS_PCT, Math.min(OUTER_RADIUS_PCT, INNER_RADIUS_PCT + spiralRadius + radiusJitter + centerBias));

  const sizePct = 16 + recencyWeight * 15;

  return {
    activity,
    xPct: 50 + Math.cos(angle) * radius,
    yPct: 50 + Math.sin(angle) * radius,
    sizePct,
    initials: getInitials(activity.data.organization),
    zIndex: 10 + Math.round(recencyWeight * 80),
  };
});

for (let iteration = 0; iteration < COLLISION_ITERATIONS; iteration += 1) {
  for (let i = 0; i < nodes.length; i += 1) {
    for (let j = i + 1; j < nodes.length; j += 1) {
      const a = nodes[i];
      const b = nodes[j];
      const dx = b.xPct - a.xPct;
      const dy = b.yPct - a.yPct;
      const distance = Math.hypot(dx, dy) || 0.001;
      const minimumDistance = (a.sizePct + b.sizePct) / 2 + COLLISION_PADDING_PCT;

      if (distance < minimumDistance) {
        const overlap = (minimumDistance - distance) / 2;
        const ux = dx / distance;
        const uy = dy / distance;

        a.xPct -= ux * overlap;
        a.yPct -= uy * overlap;
        b.xPct += ux * overlap;
        b.yPct += uy * overlap;
      }
    }
  }

  for (const node of nodes) {
    node.xPct += (50 - node.xPct) * CENTER_PULL;
    node.yPct += (50 - node.yPct) * CENTER_PULL;

    const edgeInset = node.sizePct / 2 + 0.35;
    node.xPct = Math.min(100 - edgeInset, Math.max(edgeInset, node.xPct));
    node.yPct = Math.min(100 - edgeInset, Math.max(edgeInset, node.yPct));
  }
}

for (const node of nodes) {
  const edgeInset = node.sizePct / 2 + 0.35;
  node.xPct = Math.min(100 - edgeInset, Math.max(edgeInset, node.xPct));
  node.yPct = Math.min(100 - edgeInset, Math.max(edgeInset, node.yPct));
}
---

<div class="activity-graph-shell">
  {nodes.length > 0 ? (
    <div class="activity-graph" role="list" aria-label="Activities graph">
      {nodes.map((node) => {
        const { data } = node.activity;
        const horizontalClass = node.xPct > 72 ? 'tooltip-left' : node.xPct < 28 ? 'tooltip-right' : 'tooltip-center';
        const verticalClass = node.yPct > 70 ? 'tooltip-up' : 'tooltip-down';

        return (
          <a
            href={data.website}
            target="_blank"
            rel="noopener noreferrer"
            class="activity-node group"
            role="listitem"
            title={`${data.organization} - ${data.role}`}
            style={`left:${node.xPct}%; top:${node.yPct}%; --node-size:${node.sizePct}%; --node-z:${node.zIndex};`}
            aria-label={`${data.organization}: ${data.role} (${data.date})`}
          >
            <span class="node-core">
              {data.logo ? (
                <img
                  src={data.logo}
                  alt={data.logoAlt ?? `${data.organization} logo`}
                  class="h-full w-full object-contain rounded-none drop-shadow-[0_9px_18px_rgba(0,0,0,0.35)]"
                  loading="lazy"
                />
              ) : (
                <span class="node-fallback glass">{node.initials}</span>
              )}
            </span>

            <span class={`node-tooltip ${horizontalClass} ${verticalClass}`} role="presentation">
              <strong class="block text-sm leading-tight text-foreground">{data.organization}</strong>
              <span class="mt-1 block text-xs text-foreground/80">{data.role}</span>
              <span class="mt-1 block text-[11px] text-muted-foreground">{data.date}</span>
              {data.notes && data.notes.length > 0 && (
                <ul class="mt-2 space-y-1 text-[11px] leading-snug text-foreground/90">
                  {data.notes.map((note) => (
                    <li class="note-item">{note}</li>
                  ))}
                </ul>
              )}
            </span>
          </a>
        );
      })}
    </div>
  ) : (
    <p class="text-muted-foreground">No activities loaded yet.</p>
  )}
</div>

<style>
  .activity-graph-shell {
    position: relative;
    border-radius: 2rem;
    overflow: visible;
    padding: 0.5rem;
  }

  .activity-graph-shell::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background:
      radial-gradient(circle at 50% 45%, rgba(80, 160, 255, 0.18), transparent 52%),
      radial-gradient(circle at 70% 70%, rgba(255, 160, 90, 0.14), transparent 46%),
      linear-gradient(145deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.01));
    backdrop-filter: blur(16px);
    z-index: 0;
    pointer-events: none;
  }

  .activity-graph {
    position: relative;
    z-index: 1;
    aspect-ratio: 1 / 1;
    width: 100%;
    margin: 0 auto;
    min-height: clamp(18.5rem, 48vw, 34rem);
    isolation: isolate;
  }

  .activity-node {
    position: absolute;
    transform: translate(-50%, -50%);
    width: var(--node-size);
    height: var(--node-size);
    max-width: 11rem;
    max-height: 11rem;
    min-width: 4rem;
    min-height: 4rem;
    z-index: var(--node-z);
    display: grid;
    place-items: center;
  }

  .activity-node:hover,
  .activity-node:focus-visible {
    z-index: 100;
  }

  .node-core {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    transition:
      transform 180ms ease,
      filter 180ms ease;
  }

  .activity-node:hover .node-core,
  .activity-node:focus-visible .node-core {
    transform: scale(1.08);
    filter: drop-shadow(0 10px 20px rgba(0, 0, 0, 0.28));
  }

  .node-fallback {
    width: 100%;
    height: 100%;
    border-radius: 0.9rem;
    display: grid;
    place-items: center;
    font-size: clamp(0.72rem, 0.52rem + 0.45vw, 0.95rem);
    font-weight: 700;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.9);
  }

  .node-tooltip {
    position: absolute;
    left: 50%;
    top: calc(100% + 0.65rem);
    transform: translate(-50%, 4px);
    width: min(14rem, 76vw);
    border-radius: 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.24);
    background: rgba(10, 16, 26, 0.94);
    padding: 0.65rem 0.75rem;
    pointer-events: none;
    opacity: 0;
    transition:
      opacity 170ms ease,
      transform 170ms ease;
    text-align: left;
    white-space: normal;
    max-height: min(15rem, 58vh);
    overflow-y: auto;
  }

  .node-tooltip.tooltip-left {
    left: auto;
    right: calc(50% + 0.2rem);
    transform: translate(0, 4px);
  }

  .node-tooltip.tooltip-right {
    left: calc(50% + 0.2rem);
    right: auto;
    transform: translate(0, 4px);
  }

  .node-tooltip.tooltip-center {
    left: 50%;
    right: auto;
    transform: translate(-50%, 4px);
  }

  .node-tooltip.tooltip-up {
    top: auto;
    bottom: calc(100% + 0.65rem);
  }

  .node-tooltip.tooltip-down {
    top: calc(100% + 0.65rem);
    bottom: auto;
  }

  .note-item {
    position: relative;
    padding-left: 0.75rem;
  }

  .note-item::before {
    content: '•';
    position: absolute;
    left: 0;
    top: 0;
    color: rgba(255, 255, 255, 0.62);
  }

  .activity-node:hover .node-tooltip,
  .activity-node:focus-visible .node-tooltip {
    opacity: 1;
  }

  .activity-node:hover .node-tooltip.tooltip-left,
  .activity-node:focus-visible .node-tooltip.tooltip-left {
    transform: translate(0, 0);
  }

  .activity-node:hover .node-tooltip.tooltip-right,
  .activity-node:focus-visible .node-tooltip.tooltip-right {
    transform: translate(0, 0);
  }

  .activity-node:hover .node-tooltip.tooltip-center,
  .activity-node:focus-visible .node-tooltip.tooltip-center {
    transform: translate(-50%, 0);
  }

  @media (max-width: 640px) {
    .activity-graph-shell {
      padding: 0.35rem;
      border-radius: 1.4rem;
    }

    .activity-graph {
      min-height: 18.25rem;
    }

    .node-tooltip {
      width: min(12.5rem, 76vw);
    }
  }
</style>
