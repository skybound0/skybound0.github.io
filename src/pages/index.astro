---
import RootLayout from '../layouts/RootLayout.astro';
import { Button } from '../components/ui/Button';
import { getCollection } from 'astro:content';
import ActivityGraph from '../components/ActivityGraph.astro';

const activities = await getCollection('activities');
const buddyBox = await getCollection('buddyBox');
const buddyBoxData = buddyBox[0]?.data;
---

<RootLayout title="Eric Gu" description="Projects, cooking, and more">
  <div class="page-container-home">
    <section
      class="relative grid grid-cols-[auto,1fr] sm:flex sm:flex-row gap-6 sm:gap-8 items-start mb-16 glass-strong rounded-[2rem] p-6 sm:p-8 backdrop-blur-3xl"
      style="background: rgba(255, 255, 255, 0.02)"
    >
      <div class="relative z-10 flex-shrink-0">
        <div class="w-28 h-28 sm:w-32 sm:h-32 relative rounded-full overflow-hidden border border-white/30">
          <img src="/pfp2.png" alt="Eric Gu" class="w-full h-full object-cover" />
        </div>
      </div>

      <div class="relative z-10 flex-grow">
        <h1 class="text-3xl sm:text-4xl font-bold mb-3 sm:mb-4 gradient-text">Eric Gu</h1>

        <div class="flex gap-4 mb-4">
          <a href="https://www.linkedin.com/in/eric-t-gu/" target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-primary transition-colors" aria-label="LinkedIn">
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"></path></svg>
          </a>
          <a href="mailto:eric.gu@berkeley.edu" class="text-muted-foreground hover:text-primary transition-colors" aria-label="Email">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          </a>
        </div>

        <div class="hidden sm:block text-base text-muted-foreground leading-relaxed mb-6 space-y-1">
          <p>Mechanical Engineering + Electrical Engineering & Computer Science</p>
          <p><em>University of California, Berkeley</em>, '28</p>
          <p>I enjoy all things mechatronics, including robots, drones, and 3D printers!</p>
        </div>

        <div class="hidden sm:flex gap-3 sm:gap-4">
          <Button asChild variant="default" className="bg-primary/20 hover:bg-primary/30 border border-primary/30"><a href="/projects">Projects</a></Button>
          <Button asChild variant="outline" className="border-white/30 hover:bg-primary/10"><a href="/cooking">Cooking</a></Button>
          <Button asChild variant="outline" className="border-white/30 hover:bg-primary/10"><a href="/Gu_Eric_Resume_3_20_2026.pdf" target="_blank" rel="noopener noreferrer">Resume</a></Button>
        </div>
      </div>

      <div class="sm:hidden col-span-2 text-base text-muted-foreground leading-relaxed mt-4 space-y-1">
        <p>Mechanical Engineering + Electrical Engineering & Computer Science</p>
        <p><em>University of California, Berkeley</em>, '28</p>
        <p>I enjoy all things mechatronics, including robots, drones, and 3D printers!</p>
        <div class="mt-3 flex gap-3">
          <Button asChild variant="default" className="bg-primary/20 hover:bg-primary/30 border border-primary/30"><a href="/projects">Projects</a></Button>
          <Button asChild variant="outline" className="border-white/30 hover:bg-primary/10"><a href="/cooking">Cooking</a></Button>
          <Button asChild variant="outline" className="border-white/30 hover:bg-primary/10"><a href="/Gu_Eric_Resume_3_20_2026.pdf" target="_blank" rel="noopener noreferrer">Resume</a></Button>
        </div>
      </div>
    </section>

    <div class="separator-gradient mb-12"></div>

    <section>
      <h2 class="section-title">What I'm Involved In</h2>
      <div class="mx-auto w-full max-w-[36rem]">
        <ActivityGraph activities={activities} />
      </div>
    </section>

    <div class="separator-gradient my-12"></div>

    <section>
      {buddyBoxData ? (
        <>
          <div class="flex flex-wrap justify-center items-center gap-4 sm:gap-5">
            {buddyBoxData.items.map((item) => (
              <a
                href={item.link}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center transition-opacity hover:opacity-90"
                aria-label={item.alt}
                title={item.alt}
              >
                <div class="w-[158px] sm:w-[176px]" style="aspect-ratio: 88 / 31;">
                  <img src={item.image} alt={item.alt} class="w-full h-full object-contain" />
                </div>
              </a>
            ))}
          </div>
        </>
      ) : (
        <p class="text-muted-foreground">Add buddy box content in src/content/buddy-box/index.md</p>
      )}
    </section>
  </div>
</RootLayout>
